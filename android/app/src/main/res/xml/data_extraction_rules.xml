<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) replacement for `allowBackup`. Splits backup into
  two destinations — cloud-backup (off-device) and device-transfer (D2D,
  same user) — so we can be more permissive for physical transfers than
  for cloud.

  Both destinations include the `file` domain (trail.db + salt file).
  Because `<include>` tags are exclusive (everything outside is implicitly
  excluded), we don't need an explicit `<exclude>` for sharedpref —
  FlutterSecureStorage's EncryptedSharedPreferences is Keystore-bound and
  already left out. An explicit exclude would be a lint error
  (FullBackupContent: "not in an included path").

  Both destinations use the same rules: the adversary model doesn't
  change between cloud backup and D2D transfer — the encrypted DB + salt
  + stolen passphrase produces plaintext in either case.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="."/>
        <!-- Sideloaded `.pmtiles` regions: too large for the 25 MB
             per-app cloud quota and trivially re-sideloaded after
             restore. -->
        <exclude domain="file" path="tiles/"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="."/>
        <!-- Same rationale as cloud-backup. D2D could technically
             handle the size, but keeping the rules symmetric avoids
             surprise state after a device migration. -->
        <exclude domain="file" path="tiles/"/>
    </device-transfer>
</data-extraction-rules>
