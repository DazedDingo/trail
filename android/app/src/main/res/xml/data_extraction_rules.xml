<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) replacement for `allowBackup`. Splits backup into
  two destinations — cloud-backup (off-device) and device-transfer (D2D,
  same user) — so we can be more permissive for physical transfers than
  for cloud.

  Both destinations include the `file` domain (trail.db + salt file) and
  exclude `sharedpref` (Keystore-bound, see backup_rules.xml rationale).

  We treat the two destinations the same because the adversary model
  doesn't change — the encrypted DB + salt + stolen passphrase produces
  plaintext in either case, and an attacker with physical device transfer
  has more capable alternatives anyway.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="."/>
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="."/>
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
    </device-transfer>
</data-extraction-rules>
