<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location: scheduled 4h pings need ACCESS_BACKGROUND_LOCATION. Coarse
         is included as a fallback for devices/users who deny fine. Fine is
         required for Wi-Fi SSID reads on Android 10+. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- Boot receiver wakes up after reboot to re-enqueue WorkManager and
         log a `boot` marker row. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Exact alarms: declared now so Phase 5 can toggle between
         WorkManager-only and AlarmManager-exact paths without a manifest
         change. The Phase 1 scheduler is WorkManager-only. USE_EXACT_ALARM
         is granted automatically on API 33+; SCHEDULE_EXACT_ALARM must be
         requested at runtime on API 31+. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- Panic foreground service (Phase 2). Declared up front so manifest
         validation happens early. Phase 1 never starts an FG service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>

    <!-- Android 13+ runtime notifications permission (panic receipt,
         missed-heartbeat warnings). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Auto-send panic SMS (0.6.1+16). Off by default — users opt in from
         Settings → Panic → Auto-send SMS. When enabled, the Flutter side
         fires this after a 5-second on-screen undo grace so an accidental
         panic tap can still be rescued. We don't bundle this with the Play
         Store SEND_SMS review pipeline because Trail is sideload-only. -->
    <uses-permission android:name="android.permission.SEND_SMS"/>

    <!-- Wi-Fi SSID on Android 13+ requires NEARBY_WIFI_DEVICES in addition
         to fine location. We never trigger active scans (battery rule) —
         only `getConnectionInfo` reads. -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33"/>

    <!-- Cell tower ID read via TelephonyManager.getAllCellInfo() requires
         READ_PHONE_STATE (and fine location). -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>

    <!-- Opt out of OEM aggressive doze so the 4h worker runs on time. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <!-- local_auth biometric prompt (lock screen + onboarding bio test).
         USE_BIOMETRIC covers API 28+; USE_FINGERPRINT is the legacy path
         for API 23-27 — both are required for full coverage on minSdk 23.
         Without these, LocalAuthentication.canCheckBiometrics returns
         false and no fingerprint UI is ever offered. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <uses-permission android:name="android.permission.USE_FINGERPRINT"/>

    <!-- Trail-map viewer pulls OpenStreetMap raster tiles over HTTPS. The
         logging pipeline itself never touches the network — only the
         history visualisation does. Offline devices fall back to the
         flutter_map cached-tile layer; the app stays fully usable for
         logging, export, and reading raw coordinates. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:label="Trail"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Continuous-panic foreground service (Phase 2). `location` type
             keeps GPS usable while the service is foregrounded on Android 14+.
             Not exported: only our own package starts/stops it (either from
             the Flutter MethodChannel or the Phase 3 tile/widget). -->
        <service
            android:name=".PanicForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"/>

        <!-- Quick-settings tile (Phase 3). `exported=true` is required —
             the system launcher needs to bind. `BIND_QUICK_SETTINGS_TILE`
             locks binding to the system so a malicious app can't abuse
             it. Icon reuses the launcher mono-drawable; a dedicated
             mono-icon lands in Phase 6 polish. -->
        <service
            android:name=".PanicTileService"
            android:icon="@android:drawable/ic_menu_mylocation"
            android:label="Panic"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
        </service>

        <!-- Home-screen widget (Phase 3). `exported=true` again required
             so the launcher can bind. Same panic ignition path as the
             QS tile → PanicForegroundService.start(). -->
        <receiver
            android:name=".PanicWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="com.dazeddingo.trail.WIDGET_PANIC"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/panic_widget_info"/>
        </receiver>

        <!-- Phase 5 exact-alarm receiver. Fires at the user's 4h cadence
             when scheduling mode is "precise" (Settings → Scheduling).
             Not exported: only our own [ExactAlarmScheduler] schedules
             the alarm that routes here. On fire, re-enters the Flutter
             isolate via BackgroundWorker (same path as BootReceiver) and
             schedules the next exact alarm. -->
        <receiver
            android:name=".ExactAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dazeddingo.trail.EXACT_SCHEDULED_PING"/>
            </intent-filter>
        </receiver>

        <!-- Boot marker: enqueues a one-off WorkManager task that logs a
             `boot` row and triggers an immediate GPS fix. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>
</manifest>
